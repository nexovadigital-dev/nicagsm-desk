msgstr "Automatic identification of logged-in customers"

msgid "Control total de visibilidad por página o producto"
msgstr "Full visibility control per page or product"

msgid "Iniciar sesión en Nexova Desk"
msgstr "Sign in to Nexova Desk"

msgid "Se abrirá una ventana segura para autorizar la conexión."
msgstr "A secure window will open to authorize the connection."

msgid "Gratuito"
msgstr "Free"

msgid "Prueba"
msgstr "Trial"

msgid "Plan: %s"
msgstr "Plan: %s"

